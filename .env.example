# ── Provider ──────────────────────────────────────────
# 可选: codex, gemini-cli, cursor-cli
# 可在 Web UI 中随时切换，无需重启
PROVIDER=codex

# ── Codex CLI ────────────────────────────────────────
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=read-only
CODEX_SYSTEM_PROMPT=
# 工作目录，留空则使用当前目录
CODEX_WORKDIR=

# ── Gemini CLI ───────────────────────────────────────
GEMINI_CLI_BIN=gemini
GEMINI_CLI_MODEL=
# 可选: yolo（自动批准）, auto-edit, confirm
GEMINI_CLI_APPROVAL_MODE=yolo

# ── Cursor CLI ────────────────────────────────────────
CURSOR_CLI_BIN=agent
# 工作区路径（可选，默认用 CODEX_WORKDIR）
CURSOR_CLI_WORKSPACE=
# API Key（可选，也可用已登录状态）
CURSOR_API_KEY=

# ── Web ──────────────────────────────────────────────
WEB_PORT=19981

# ── 日志 ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_INCLUDE_CONTENT=false
LOG_INCLUDE_PROMPT=false
