# Fixed provider
PROVIDER=codex

# Codex CLI
# Set CODEX_BIN explicitly on Windows if codex is not available in PATH.
CODEX_BIN=
CODEX_MODEL=gpt-5.4
CODEX_SANDBOX=danger-full-access
CODEX_SYSTEM_PROMPT=
# Leave empty to use the current working directory.
CODEX_WORKDIR=

# Web UI
WEB_PORT=19981

# Logging
LOG_LEVEL=info
LOG_INCLUDE_CONTENT=false
LOG_INCLUDE_PROMPT=false

# Optional proxy examples
# PROXY_URL=http://127.0.0.1:7890
# PROXY_URL=socks5://127.0.0.1:7891
