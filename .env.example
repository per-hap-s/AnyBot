# ── Codex ────────────────────────────────────────────
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=read-only
CODEX_SYSTEM_PROMPT=
# Codex 的工作目录，留空则使用当前目录
CODEX_WORKDIR=

# ── Web ──────────────────────────────────────────────
WEB_PORT=19981

# ── 日志 ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_INCLUDE_CONTENT=false
LOG_INCLUDE_PROMPT=false
